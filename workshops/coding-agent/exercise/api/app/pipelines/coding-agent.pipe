      "name": "Git DevOps",
      "config": {
        "authType": "none",
        "readOnlyMode": false,
        "repoPath": "${ROCKETRIDE_OUTPUT_DIR}",
        "safeMode": false,
        "sshKey": "",
        "sshPassphrase": "",
