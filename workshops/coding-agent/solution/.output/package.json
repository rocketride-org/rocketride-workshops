{
  "name": "todo-app",
  "version": "1.0.0",
  "private": true,
  "description": "Todo app with React frontend and Express backend",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npx vite",
    "dev": "node -e \"const{spawn}=require('child_process');const s=spawn('node',['server/index.js'],{stdio:'inherit'});const c=spawn('npx',['vite'],{cwd:'client',stdio:'inherit',shell:true});process.on('SIGINT',()=>{s.kill();c.kill();process.exit();})\"",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2"
  }
}
