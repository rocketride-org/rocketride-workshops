    {
      "id": "llm_anthropic_pm",
      "provider": "llm_anthropic",
      "name": "Anthropic PM",
      "config": {
        "profile": "claude-sonnet-4-6",
        "claude-sonnet-4-6": {
          "modelSource": "manual",
          "apikey": "${ROCKETRIDE_ANTHROPIC_KEY}"
        },
        "name": "Anthropic PM"
      },
      "ui": {
        "position": {
          "x": 830,
          "y": 320
        },
        "nodeType": "default",
