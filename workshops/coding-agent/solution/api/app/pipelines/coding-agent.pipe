    {
      "id": "agent_deepagent_1",
      "provider": "agent_deepagent",
      "name": "Deep Agent",
      "config": {
        "profile": "default",
        "default": {
          "advanced_mode": false,
          "agent_description": "Cody Rider — a coding agent. Builds what the user asks, decisively.",
          "instructions": [
            "Project root: ${ROCKETRIDE_OUTPUT_DIR}.",
            "Tools: tool_shell, tool_filesystem, tool_git.",
            "Reply concise unless the user asks for detail.",
            "If the project root doesn't exist yet, create it with tool_filesystem before listing or writing files.",
            "Long-running processes: spawn detached, redirect to server.log, capture PID, probe to verify. Windows `start /b cmd /c`, Unix `nohup ... &`. Stop by PID only — never by image name (`taskkill /IM`, `pkill <name>`, `Get-Process X | Stop-Process`); those kill the engine running this chat."
          ]
        },
        "name": "Deep Agent"
      },
      "ui": {
        "position": {
          "x": 1540,
          "y": 540
        },
        "nodeType": "default",
        "formDataValid": true
      },
